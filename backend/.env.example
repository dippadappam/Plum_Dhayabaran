# Copy this file to .env (in the backend/ directory) and paste your own
# Anthropic API key after the =. backend/.env is gitignored, so your key is
# never committed. Get a key at https://console.anthropic.com/
#
# The server loads this file at startup via:
#   python -m uvicorn app.api:app --port 8000 --env-file .env
#
# Optional: leave the key blank to run the deterministic path only (the 12
# official test cases, the eval report, and the web UI all work without a key;
# only live extraction of uploaded document images needs it).
ANTHROPIC_API_KEY=
